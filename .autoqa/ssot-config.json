{
  "defaultCreateEnvironment": "local",
  "defaultRunEnvironment": "local",
  "defaultProject": "chrome",
  "environments": {
    "local": {
      "baseURL": "http://localhost:3000",
      "allowGeneration": true,
      "allowRegressionRun": true
    }
  },
  "auth": {
    "provider": "app-local",
    "email": "REPLACE-TEST-ACCOUNT-EMAIL",
    "password": "REPLACE-TEST-ACCOUNT-PASSWORD",
    "defaultReturnTo": "/"
  },
  "run": {
    "headedFlag": "--headed",
    "regCasesPath": ".autoqa/rg-cases",
    "ticketsPath": ".autoqa/tickets",
    "workingDirectory": ".",
    "playwrightConfig": "playwright.config.ts"
  },
  "semanticCheck": {
    "baseURL": "https://finleyswedencentralinstance.openai.azure.com/openai/v1",
    "envKey": "AZURE_OPENAI_API_KEY",
    "model": "gpt-5.4",
    "reasoningEffort": "medium"
  },
  "db": {
    "stack": "ts",
    "engineeringRulesPath": ".prodfarm/charter/engineering-rules.md",
    "backendRoot": ".",
    "connectionModule": "app/src/lib/db.ts",
    "envFile": ".env",
    "envKeys": {
      "local": "EASYAPP_DATABASE_URL",
      "deployed": "DATABASE_URL"
    },
    "schema": {
      "default": "whichtouse-schema"
    },
    "ssot": {
      "ddlPath": "ssot-schemas/db-schemas/whichtouse.sql"
    },
    "fixtureScripts": {
      "workingDirectory": ".",
      "tmpDirectory": ".autoqa/run-artifacts/tmp",
      "idempotentRequired": true,
      "canonicalAccessRequired": true
    },
    "writePolicy": {
      "defaultEnvironment": "local",
      "allowedEnvironments": [
        "local"
      ],
      "deniedEnvironments": [
        "prod"
      ],
      "requiresManifestAllowResetEnvironment": true
    },
    "testPrincipals": {
      "learner": {
        "ownerColumns": [
          "user_id"
        ],
        "lookup": {
          "emailEnv": "AUTOQA_LEARNER_EMAIL"
        }
      }
    },
    "cleanupResources": {
      "publicDocument": {
        "uniqueConstraint": "public_documents_slug_key",
        "allowedKeyFields": [
          "slug"
        ],
        "keyRules": {
          "slug": {
            "prefix": "autoqa-"
          }
        }
      }
    },
    "fixtureProcesses": {}
  },
  "policy": {
    "generateTestsAgainst": "local",
    "doNotHardcodeEnvironmentUrlsInSpecs": true,
    "storeTestAccountCredentialsInSsotConfig": true
  }
}
